{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gtnh-insight-atlas.local/schemas/fact.schema.json",
  "title": "Atlas Fact",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "label", "value", "unit", "source", "verification"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)*$"
    },
    "label": {
      "type": "string",
      "minLength": 1
    },
    "value": {
      "oneOf": [
        { "type": "string" },
        { "type": "number" },
        { "type": "boolean" },
        { "type": "array" }
      ]
    },
    "unit": {
      "type": "string"
    },
    "source": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["file", "line", "version"],
        "properties": {
          "file": {
            "type": "string",
            "minLength": 1
          },
          "line": {
            "type": "integer",
            "minimum": 1
          },
          "end_line": {
            "type": "integer",
            "minimum": 1
          },
          "version": {
            "const": "5.09.52.594"
          },
          "expect": {
            "type": "string"
          }
        }
      }
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "method"],
      "properties": {
        "status": {
          "enum": ["verified", "source-only", "pending", "contradicted"]
        },
        "method": {
          "type": "string",
          "minLength": 1
        },
        "record": {
          "type": "string"
        }
      }
    },
    "notes": {
      "type": "string"
    }
  }
}
